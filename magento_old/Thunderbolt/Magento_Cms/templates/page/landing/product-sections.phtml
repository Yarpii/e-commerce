/** @var \Magento\Framework\View\Element\Template $block */

/* -----------------------------------------------------------------------
 * Product Sections — no custom block class required.
 * Logic runs entirely here via ObjectManager so no DI compilation is needed.
 * ----------------------------------------------------------------------- */

$objectManagerClass = 'Magento\\Framework\\App\\ObjectManager';
