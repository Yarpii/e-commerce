/** @var array<string, array<string, mixed>> $rawSections */
$rawSections = $block->getData('sections') ?: [];

// ── helpers ──────────────────────────────────────────────────────────────

$getCollection = static function (int $limit, array $idsFilter = [], int $catId = 0)
    use ($om, $visibility, $collectionFactory, $categoryRepo, $storeManager): array {

    /** @var \Magento\Catalog\Model\ResourceModel\Product\Collection $col */
    $col = $collectionFactory->create();
    $col->addAttributeToFilter('status', 1);
    $col->setVisibility($visibility->getVisibleInCatalogIds());
    $col->addAttributeToSelect(['name', 'small_image', 'price', 'special_price']);
    $col->setPageSize($limit);

    if ($idsFilter !== []) {
        $col->addIdFilter($idsFilter);
    } elseif ($catId > 0) {
        try {
            $cat = $categoryRepo->get($catId, $storeManager->getStore()->getId());
            $col->addCategoriesFilter(['in' => [$cat->getId()]]);
        } catch (\Throwable $e) {
            // category not found — fall through to latest
        }
    } else {
        $col->setOrder('created_at', 'DESC');
    }

    $products = [];
    foreach ($col as $product) {
        $products[] = $product;
    }
    return $products;
};

$parseIds = static function (string $raw): array {
    if ($raw === '') {
        return [];
    }
    return array_values(array_unique(array_filter(array_map('intval', explode(',', $raw)))));
};

$getMockImageUrl = static function (int $idx) use ($assetRepo): string {
    $n = ($idx % 4) + 1;
    try {
        return $assetRepo->getUrl('images/landing/mock-product-' . $n . '.svg');
    } catch (\Throwable $e) {
        return '';
    }
};

$formatPrice = static function ($product) use ($priceHelper): string {
    $price = (float) $product->getFinalPrice();
    if ($price <= 0) {
        return '';
    }
    return (string) $priceHelper->currency($price, true, false);
};

$formatBasePrice = static function ($product) use ($priceHelper): string {
    $price = (float) $product->getPrice();
    if ($price <= 0) {
        return '';
    }
    return (string) $priceHelper->currency($price, true, false);
};

