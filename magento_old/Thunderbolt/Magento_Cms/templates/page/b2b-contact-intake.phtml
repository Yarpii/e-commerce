$contactPostUrl = $block->getUrl('siteform/index/post');
?>
<section class="mx-auto w-[92%] py-8 sm:w-[90%] md:w-[88%] md:py-10 lg:w-[85%]">
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm md:p-8">
        <p class="inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-muted)]">
            <?= $escaper->escapeHtml(__('B2B Team Intake')) ?>
        </p>
        <h1 class="mt-4 text-2xl font-black tracking-tight text-[var(--color-text)] md:text-4xl">
            <?= $escaper->escapeHtml(__('B2B Contact & Intake')) ?>
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
            <?= $escaper->escapeHtml(__('Use this form for wholesale, distribution, workshop groups, and strategic brand requests. We review fit, capacity, and rollout potential before onboarding.')) ?>
        </p>
    </div>

    <div class="mt-6 grid gap-5 lg:grid-cols-[minmax(0,1.3fr)_minmax(280px,1fr)] lg:items-start">
        <form
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm md:p-8"
            method="post"
            action="<?= $escaper->escapeUrl($contactPostUrl) ?>"
            x-data="{
                sending:false,
                errorMessage:'',
                formStartedAt:Date.now(),
                minFillMs:3000,
                throttleMs:90000,
                throttleKey:'sd-b2b-intake-submit',
                shouldBlockSpam(){
                    const honey=(this.$refs.hp.value||'').toString().trim();
                    if(honey!==''){this.errorMessage='Formulier kon niet verzonden worden.';return true;}
                    if(Date.now()-this.formStartedAt<this.minFillMs){this.errorMessage='Wacht heel even en probeer opnieuw.';return true;}
                    const lastSubmit=Number(window.localStorage.getItem(this.throttleKey)||0);
                    if(lastSubmit>0&&Date.now()-lastSubmit<this.throttleMs){
                        const waitSeconds=Math.ceil((this.throttleMs-(Date.now()-lastSubmit))/1000);
                        this.errorMessage='Je hebt net verzonden. Probeer opnieuw over '+waitSeconds+'s.';
                        return true;
                    }
                    return false;
                },
                buildSummary(){
                    const lines=[];
                    const pushLine=(label,value)=>{const clean=(value||'').toString().trim(); if(clean!==''){lines.push(label+': '+clean);}};
                    lines.push('Nieuwe B2B intake via /b2b-contact-intake');
                    lines.push('');
                    pushLine('Datum/tijd',new Date().toLocaleString('nl-NL'));
                    pushLine('Pagina URL',window.location.href);
                    pushLine('Bedrijf',this.$refs.company.value);
                    pushLine('Type aanvraag',this.$refs.requestType.value);
                    pushLine('Regio',this.$refs.region.value);
                    const message=(this.$refs.notes.value||'').toString().trim();
                    if(message!==''){lines.push(''); lines.push('Notities:'); lines.push(message);}
                    this.$refs.commentInput.value=lines.join('\n');
                },
                submitForm(){
                    this.errorMessage='';
                    if(this.shouldBlockSpam()){return;}
                    this.buildSummary();
                    this.sending=true;
                    try{window.localStorage.setItem(this.throttleKey,String(Date.now()));}catch(e){}
                    this.$el.submit();
                }
            }"
            @submit.prevent="submitForm()"
        >
            <?= $block->getBlockHtml('formkey') ?>
            <input type="hidden" name="form_label" value="B2B intake" />
            <input type="hidden" name="comment" x-ref="commentInput" />
            <input type="text" name="company_website" x-ref="hp" tabindex="-1" autocomplete="off" class="absolute left-[-9999px] top-auto h-0 w-0 overflow-hidden" aria-hidden="true" />

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-name"><?= $escaper->escapeHtml(__('Contact person')) ?></label>
                    <input id="b2b-name" name="name" required class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm" type="text" />
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-email"><?= $escaper->escapeHtml(__('Business email')) ?></label>
                    <input id="b2b-email" name="email" required class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm" type="email" />
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-phone"><?= $escaper->escapeHtml(__('Phone')) ?></label>
                    <input id="b2b-phone" name="telephone" class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm" type="text" />
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-company"><?= $escaper->escapeHtml(__('Company')) ?></label>
                    <input id="b2b-company" name="b2b_company" x-ref="company" required class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm" type="text" />
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-type"><?= $escaper->escapeHtml(__('Request type')) ?></label>
                    <select id="b2b-type" name="b2b_type" x-ref="requestType" class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm">
                        <option value=""><?= $escaper->escapeHtml(__('Select type')) ?></option>
                        <option value="Wholesale"><?= $escaper->escapeHtml(__('Wholesale')) ?></option>
                        <option value="Distribution"><?= $escaper->escapeHtml(__('Distribution')) ?></option>
                        <option value="Workshop Group"><?= $escaper->escapeHtml(__('Workshop Group')) ?></option>
                        <option value="Brand Partnership"><?= $escaper->escapeHtml(__('Brand Partnership')) ?></option>
                    </select>
                </div>
                <div class="sm:col-span-2">
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-region"><?= $escaper->escapeHtml(__('Target region(s)')) ?></label>
                    <input id="b2b-region" name="b2b_region" x-ref="region" class="h-11 w-full rounded-lg border border-[var(--color-border)] bg-white px-3 text-sm" type="text" placeholder="EU, DACH, Benelux..." />
                </div>
                <div class="sm:col-span-2">
                    <label class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]" for="b2b-notes"><?= $escaper->escapeHtml(__('Project notes')) ?></label>
                    <textarea id="b2b-notes" name="b2b_notes" x-ref="notes" required rows="5" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 text-sm" placeholder="Tell us what you want to launch and your target timeline."></textarea>
                </div>
            </div>

            <p class="mt-4 text-sm text-rose-600" x-show="errorMessage" x-text="errorMessage"></p>
            <button type="submit" class="mt-5 inline-flex items-center rounded-lg border border-[var(--color-accent)] bg-[var(--color-accent)] px-4 py-2.5 text-sm font-semibold text-white" :disabled="sending">
                <span x-show="!sending"><?= $escaper->escapeHtml(__('Send intake')) ?></span>
                <span x-show="sending"><?= $escaper->escapeHtml(__('Sending...')) ?></span>
            </button>
        </form>

        <aside class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm md:p-7">
            <h3 class="text-base font-bold text-[var(--color-text)]"><?= $escaper->escapeHtml(__('What to expect')) ?></h3>
            <ol class="mt-3 space-y-2 text-sm text-[var(--color-muted)]">
                <li>1. <?= $escaper->escapeHtml(__('Initial fit check in 1 business day')) ?></li>
                <li>2. <?= $escaper->escapeHtml(__('Commercial and operational alignment')) ?></li>
                <li>3. <?= $escaper->escapeHtml(__('Onboarding proposal with next steps')) ?></li>
            </ol>
        </aside>
    </div>
</section>