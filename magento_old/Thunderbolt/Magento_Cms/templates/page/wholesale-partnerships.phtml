            method="post"
            action="<?= $escaper->escapeUrl($contactPostUrl) ?>"
            x-data="{
                sending: false,
                errorMessage: '',
                formStartedAt: Date.now(),
                minFillMs: 3500,
                throttleMs: 90000,
                throttleKey: 'sd-wholesale-submit',
                shouldBlockSpam() {
                    const honey = (this.$refs.hp.value || '').toString().trim();
                    if (honey !== '') {
                        this.errorMessage = 'Formulier kon niet verzonden worden.';
                        return true;
                    }

                    if (Date.now() - this.formStartedAt < this.minFillMs) {
                        this.errorMessage = 'Wacht heel even en probeer opnieuw.';
                        return true;
                    }

                    const lastSubmit = Number(window.localStorage.getItem(this.throttleKey) || 0);
                    if (lastSubmit > 0 && Date.now() - lastSubmit < this.throttleMs) {
                        const waitSeconds = Math.ceil((this.throttleMs - (Date.now() - lastSubmit)) / 1000);
                        this.errorMessage = 'Je hebt net verzonden. Probeer opnieuw over ' + waitSeconds + 's.';
                        return true;
                    }

                    return false;
                },
                buildSummary() {
                    const lines = [];
                    const pushLine = (label, value) => {
                        const cleanValue = (value || '').toString().trim();
                        if (cleanValue !== '') {
                            lines.push(label + ': ' + cleanValue);
                        }
                    };

                    lines.push('Nieuwe wholesale-partnership aanvraag via /wholesale-partnerships');
                    lines.push('');
                    pushLine('Datum/tijd', new Date().toLocaleString('nl-NL'));
                    pushLine('Pagina URL', window.location.href);
                    pushLine('Store code', '<?= $escaper->escapeJs($storeCode) ?>');
                    pushLine('Bedrijfsnaam', this.$refs.company.value);
                    pushLine('Business type', this.$refs.businessType.value);
                    pushLine('Regio / landen', this.$refs.regions.value);
                    pushLine('Geschatte jaaromzet (EUR)', this.$refs.revenue.value);
                    pushLine('Primaire productgroepen', this.$refs.categories.value);
                    pushLine('Campagne-samenwerking gewenst', this.$refs.campaignSupport.checked ? 'Ja' : 'Nee');

                    const logistics = (this.$refs.logistics.value || '').toString().trim();
                    if (logistics !== '') {
                        lines.push('');
                        lines.push('Logistics / fulfilment context:');
                        lines.push(logistics);
                    }

                    const notes = (this.$refs.notes.value || '').toString().trim();
                    if (notes !== '') {
                        lines.push('');
                        lines.push('Strategic notes:');
                        lines.push(notes);
                    }

                    this.$refs.commentInput.value = lines.join('\n');
                },
                submitForm() {
                    this.errorMessage = '';
                    if (this.shouldBlockSpam()) {
                        return;
                    }

                    this.buildSummary();
                    this.sending = true;
                    try {
                        window.localStorage.setItem(this.throttleKey, String(Date.now()));
                    } catch (e) {
                        // ignore storage errors
                    }
                    this.$el.submit();
                }
            }"
            @submit.prevent="submitForm()"
        >
