                    d: '--', h: '--', m: '--', s: '--',
                    init() { this.tick(); setInterval(() => this.tick(), 1000); },
                    tick() {
                        const diff = Math.max(0, this.deadline - Date.now());
                        this.d = String(Math.floor(diff / 86400000)).padStart(2, '0');
