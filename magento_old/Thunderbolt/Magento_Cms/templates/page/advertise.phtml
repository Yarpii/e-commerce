        <form
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm md:p-8"
            method="post"
            action="<?= $escaper->escapeUrl($contactPostUrl) ?>"
            x-data="{
                sending: false,
                errorMessage: '',
                formStartedAt: Date.now(),
                minFillMs: 3000,
                throttleMs: 90000,
                throttleKey: 'sd-advertise-submit',
                shouldBlockSpam() {
                    const honey = (this.$refs.hp.value || '').toString().trim();
                    if (honey !== '') {
                        this.errorMessage = 'Formulier kon niet verzonden worden.';
                        return true;
                    }

                    if (Date.now() - this.formStartedAt < this.minFillMs) {
                        this.errorMessage = 'Wacht heel even en probeer opnieuw.';
                        return true;
                    }

                    const lastSubmit = Number(window.localStorage.getItem(this.throttleKey) || 0);
                    if (lastSubmit > 0 && Date.now() - lastSubmit < this.throttleMs) {
                        const waitSeconds = Math.ceil((this.throttleMs - (Date.now() - lastSubmit)) / 1000);
                        this.errorMessage = 'Je hebt net verzonden. Probeer opnieuw over ' + waitSeconds + 's.';
                        return true;
                    }

                    return false;
                },
                buildSummary() {
                    const lines = [];
                    const pushLine = (label, value) => {
                        const cleanValue = (value || '').toString().trim();
                        if (cleanValue !== '') {
                            lines.push(label + ': ' + cleanValue);
                        }
                    };

                    lines.push('Nieuwe advertentie-aanmelding via /adverteren');
                    lines.push('');
                    pushLine('Datum/tijd', new Date().toLocaleString('nl-NL'));
                    pushLine('Pagina URL', window.location.href);
                    pushLine('Merknaam', this.$refs.adBrand.value);
                    pushLine('Website / landingspagina', this.$refs.adUrl.value);
                    pushLine('Campagne-type', this.$refs.adCampaign.value);
                    pushLine('Maandbudget indicatie', this.$refs.adBudget.value);
                    pushLine('Doelmarkt', this.$refs.adMarket.value);
                    pushLine('Productcategorieen', this.$refs.adCategories.value);
                    pushLine('Verkoopt al via ScooterDynamics', this.$refs.adExisting.checked ? 'Ja' : 'Nee');

                    const extraInfo = (this.$refs.adMessage.value || '').toString().trim();
                    if (extraInfo !== '') {
                        lines.push('');
                        lines.push('Extra info:');
                        lines.push(extraInfo);
                    }

                    this.$refs.commentInput.value = lines.join('\n');
                },
                submitForm() {
                    this.errorMessage = '';
                    if (this.shouldBlockSpam()) {
                        return;
                    }

                    this.buildSummary();
                    this.sending = true;
                    try {
                        window.localStorage.setItem(this.throttleKey, String(Date.now()));
                    } catch (e) {
                        // ignore storage errors
                    }
                    this.$el.submit();
                }
            }"
            @submit.prevent="submitForm()"
        >
