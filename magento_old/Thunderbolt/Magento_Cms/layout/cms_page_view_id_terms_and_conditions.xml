<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="cms-terms-and-conditions"/>

        <referenceBlock name="cms_page" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template" name="thunderbolt.terms.and.conditions" template="Magento_Cms::page/terms-and-conditions.phtml" before="-"/>
        </referenceContainer>
    </body>
</page>