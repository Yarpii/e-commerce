<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/source/_404.css"/>
    </head>
    <body>
        <attribute name="class" value="cms-noroute"/>

        <referenceBlock name="cms_noroute" remove="true"/>
        <referenceBlock name="cms_no_route" remove="true"/>
        <referenceBlock name="noroute" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template" name="thunderbolt.noroute" template="Magento_Cms::page/404.phtml" before="-"/>
        </referenceContainer>
    </body>
</page>