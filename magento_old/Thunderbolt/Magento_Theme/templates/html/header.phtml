                }
            },
            'ATV': {
                'Yamaha': {
                    'Kodiak 450': { '450cc': ['2019', '2020', '2021'] }
                }
            }
        },
        searchBaseUrl: '<?= $escaper->escapeJs($catalogSearchUrl) ?>',
        onScroll() {
            this.fixed = window.scrollY > this.topbarH;
        },
        emptyDraftVehicle() {
            return { type: '', manufacturer: '', model: '', engine: '', year: '' };
        },
        buildVehicleLabel(vehicle) {
            if (!vehicle) {
                return '';
            }
            return [vehicle.type, vehicle.manufacturer, vehicle.model, vehicle.engine, vehicle.year]
                .map(value => (value || '').toString().trim())
                .filter(Boolean)
                .join(' · ');
        },
        vehicleMeta(vehicle) {
            if (!vehicle) {
                return '';
            }
            return [vehicle.type, vehicle.engine, vehicle.year]
                .map(value => (value || '').toString().trim())
                .filter(Boolean)
                .join(' / ');
        },
        manufacturers() {
            return Object.keys(this.fitmentData[this.draftVehicle.type] || {});
        },
        models() {
            const byType = this.fitmentData[this.draftVehicle.type] || {};
            return Object.keys(byType[this.draftVehicle.manufacturer] || {});
        },
        engines() {
            const byType = this.fitmentData[this.draftVehicle.type] || {};
            const byManufacturer = byType[this.draftVehicle.manufacturer] || {};
            return Object.keys(byManufacturer[this.draftVehicle.model] || {});
        },
        years() {
            const byType = this.fitmentData[this.draftVehicle.type] || {};
            const byManufacturer = byType[this.draftVehicle.manufacturer] || {};
            const byModel = byManufacturer[this.draftVehicle.model] || {};
            return byModel[this.draftVehicle.engine] || [];
        },
        currentStep() {
            if (!this.draftVehicle.type) {
                return 0;
            }
            if (!this.draftVehicle.manufacturer) {
                return 1;
            }
            if (!this.draftVehicle.model) {
                return 2;
            }
            if (!this.draftVehicle.engine) {
                return 3;
            }
            if (!this.draftVehicle.year) {
                return 4;
            }
            return 5;
        },
        setType(type) {
            this.draftVehicle.type = type;
            this.draftVehicle.manufacturer = '';
            this.draftVehicle.model = '';
            this.draftVehicle.engine = '';
            this.draftVehicle.year = '';
        },
        setManufacturer(manufacturer) {
            this.draftVehicle.manufacturer = manufacturer;
            this.draftVehicle.model = '';
            this.draftVehicle.engine = '';
            this.draftVehicle.year = '';
        },
        setModel(model) {
            this.draftVehicle.model = model;
            this.draftVehicle.engine = '';
            this.draftVehicle.year = '';
        },
        setEngine(engine) {
            this.draftVehicle.engine = engine;
            this.draftVehicle.year = '';
        },
        canAddVehicle() {
            return !!(this.draftVehicle.type && this.draftVehicle.manufacturer && this.draftVehicle.model && this.draftVehicle.engine && this.draftVehicle.year && this.garageCount() < 5);
        },
        normalizeVehicle(vehicle) {
            if (!vehicle || typeof vehicle !== 'object') {
                return null;
            }
            if (vehicle.name && !vehicle.manufacturer && !vehicle.model) {
                return {
                    id: vehicle.id || Date.now(),
                    type: 'Scooter',
                    manufacturer: '',
                    model: vehicle.name,
                    engine: '',
                    year: '',
                    name: vehicle.name
                };
            }
            const normalized = {
                id: vehicle.id || Date.now(),
                type: (vehicle.type || 'Scooter').toString().trim(),
                manufacturer: (vehicle.manufacturer || '').toString().trim(),
                model: (vehicle.model || '').toString().trim(),
                engine: (vehicle.engine || '').toString().trim(),
                year: (vehicle.year || '').toString().trim()
            };
            normalized.name = this.buildVehicleLabel(normalized);
            return normalized.name ? normalized : null;
        },
        loadGarage() {
            try {
                const vehicles = JSON.parse(localStorage.getItem('thunderbolt-garage') || '[]');
                this.vehicles = Array.isArray(vehicles)
                    ? vehicles.map(vehicle => this.normalizeVehicle(vehicle)).filter(Boolean).slice(0, 5)
                    : [];
            } catch (e) {
                this.vehicles = [];
            }
            const savedMain = localStorage.getItem('thunderbolt-main-vehicle');
            this.activeVehicleId = savedMain ? Number(savedMain) : null;
            if (this.activeVehicleId === null && this.vehicles.length) {
                this.activeVehicleId = this.vehicles[0].id;
            }
        },
        persistGarage() {
            localStorage.setItem('thunderbolt-garage', JSON.stringify(this.vehicles.slice(0, 5)));
            if (this.activeVehicleId) {
                localStorage.setItem('thunderbolt-main-vehicle', String(this.activeVehicleId));
            } else {
                localStorage.removeItem('thunderbolt-main-vehicle');
            }
        },
        mainVehicle() {
            return this.vehicles.find(vehicle => vehicle.id === this.activeVehicleId) || this.vehicles[0] || null;
        },
        mainVehicleLabel() {
            const vehicle = this.mainVehicle();
            return vehicle ? vehicle.name : '';
        },
        garageCount() {
            return this.vehicles.length;
        },
        addVehicle() {
            const normalized = this.normalizeVehicle({
                id: Date.now(),
                type: this.draftVehicle.type,
                manufacturer: this.draftVehicle.manufacturer,
                model: this.draftVehicle.model,
                engine: this.draftVehicle.engine,
                year: this.draftVehicle.year
            });
            if (!this.canAddVehicle() || !normalized || this.vehicles.some(vehicle => vehicle.name.toLowerCase() === normalized.name.toLowerCase())) {
                return;
            }
            this.vehicles = [...this.vehicles, normalized];
            if (!this.activeVehicleId) {
                this.activeVehicleId = normalized.id;
            }
            this.draftVehicle = this.emptyDraftVehicle();
            this.persistGarage();
        },
        setMainVehicle(id) {
            this.activeVehicleId = id;
            this.persistGarage();
            this.garageOpen = false;
        },
        removeVehicle(id) {
            this.vehicles = this.vehicles.filter(vehicle => vehicle.id !== id);
            if (this.activeVehicleId === id) {
                this.activeVehicleId = this.vehicles.length ? this.vehicles[0].id : null;
            }
            this.persistGarage();
        },
        clearGarage() {
            this.vehicles = [];
            this.activeVehicleId = null;
            this.persistGarage();
        },
        browseMainVehicle() {
            const vehicle = this.mainVehicleLabel();
            if (!vehicle) {
                this.garageOpen = true;
                return;
            }
            const url = new URL(this.searchBaseUrl, window.location.origin);
            url.searchParams.set('q', vehicle);
            url.searchParams.set('vehicle', vehicle);
            window.location.href = url.toString();
        },
        measure() {
            this.headerH = this.$refs.mainHeader ? this.$refs.mainHeader.offsetHeight : 0;
            this.topbarH = this.$refs.topbar ? this.$refs.topbar.offsetHeight : 0;
            this.onScroll();
        }
    }"
    x-init="loadGarage(); measure(); window.addEventListener('scroll', () => onScroll(), { passive: true }); window.addEventListener('resize', () => measure())"
    @keydown.escape.window="garageOpen = false"
