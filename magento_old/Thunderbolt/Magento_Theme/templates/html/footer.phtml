if (!function_exists('__')) {
    function __($text, ...$args)
    {
        $message = (string) $text;
        return $args ? vsprintf($message, array_map('strval', $args)) : $message;
    }
}

$objectManagerClass = 'Magento\\Framework\\App\\ObjectManager';
