$getConfigUrl = static function (array $paths) use ($scopeConfig, $storeId): ?string {
    foreach ($paths as $path) {
        $value = (string) $scopeConfig->getValue($path, 'stores', $storeId);
        if ($value !== '') {
            return $value;
        }
    }

    return null;
};

