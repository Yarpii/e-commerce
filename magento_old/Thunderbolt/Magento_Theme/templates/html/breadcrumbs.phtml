<?php
/** @var \Magento\Theme\Block\Html\Breadcrumbs $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Magento\Framework\App\Request\Http $request */
$crumbs = $block->getCrumbs();

$request = $block->getRequest();
if ($request instanceof \Magento\Framework\App\Request\Http) {
    $isCatalogSearchResult = $request->getFullActionName() === 'catalogsearch_result_index';
} else {
    $isCatalogSearchResult = false;
}

if ((empty($crumbs) || !is_array($crumbs)) && $isCatalogSearchResult) {
    $queryText = trim((string) $request->getParam('q'));
    $resultLabel = $queryText !== ''
        ? (string) __('Zoekresultaten voor "%1"', $queryText)
        : (string) __('Zoekresultaten');

    $crumbs = [
        'home' => [
            'label' => (string) __('Home'),
            'title' => (string) __('Go to Home Page'),
            'link' => $block->getUrl('')
        ],
        'search_results' => [
            'label' => $resultLabel,
            'title' => $resultLabel
        ]
    ];
}

if (empty($crumbs) || !is_array($crumbs)) {
    return;
}
?>
<nav class="breadcrumbs" aria-label="<?= $escaper->escapeHtmlAttr(__('Breadcrumb')) ?>">
    <ol class="items">
        <?php $index = 0; ?>
        <?php foreach ($crumbs as $crumbName => $crumbInfo): ?>
            <?php
            $label = isset($crumbInfo['label']) ? (string) $crumbInfo['label'] : '';
            $title = isset($crumbInfo['title']) ? (string) $crumbInfo['title'] : '';
            $link = isset($crumbInfo['link']) ? (string) $crumbInfo['link'] : '';
            $hasLink = $link !== '' && empty($crumbInfo['readonly']);
            $isFirst = $index === 0;
            ?>
            <li class="item <?= $escaper->escapeHtmlAttr($crumbName) ?><?= $isFirst ? ' is-home' : '' ?>">
                <?php if ($hasLink): ?>
                    <a href="<?= $escaper->escapeUrl($link) ?>" title="<?= $escaper->escapeHtmlAttr($title ?: $label) ?>">
                        <?php if ($isFirst): ?>
                            <svg class="breadcrumb-home-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                                <path d="M10 2.8 2.5 9v8.2h5V12.5h5v4.7h5V9L10 2.8Z" fill="currentColor"/>
                            </svg>
                        <?php endif; ?>
                        <span><?= $escaper->escapeHtml($label) ?></span>
                    </a>
                <?php else: ?>
                    <strong>
                        <?php if ($isFirst): ?>
                            <svg class="breadcrumb-home-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                                <path d="M10 2.8 2.5 9v8.2h5V12.5h5v4.7h5V9L10 2.8Z" fill="currentColor"/>
                            </svg>
                        <?php endif; ?>
                        <span><?= $escaper->escapeHtml($label) ?></span>
                    </strong>
                <?php endif; ?>
            </li>
            <?php $index++; ?>
        <?php endforeach; ?>
    </ol>
</nav>