<?php
/** @var \Magento\Catalog\Block\Navigation $block */
$categories = $block->getStoreCategories();
$renderTree = static function (array $nodes, callable $renderer, \Magento\Catalog\Block\Navigation $navBlock): string {
    $html = '<ul class="space-y-1.5 border-l border-[var(--color-border)] pl-3">';
    foreach ($nodes as $node) {
        if (!$node->getIsActive()) {
            continue;
        }

        $children = [];
        foreach ($node->getChildren() as $child) {
            if ($child->getIsActive()) {
                $children[] = $child;
            }
        }

        $hasChildren = !empty($children);
        $name = $navBlock->escapeHtml(__($node->getName()));
        $url = $navBlock->escapeUrl($node->getUrl());

        $html .= '<li ' . ($hasChildren ? 'x-data="{ open: false }"' : '') . '>';

        if ($hasChildren) {
            $html .= '<div class="flex items-center gap-2">';
            $html .= '<a class="flex-1 rounded-[var(--radius-button)] px-2.5 py-2 text-sm text-[var(--color-text)] transition-colors hover:bg-[var(--color-bg)] hover:text-[var(--color-accent)]" href="' . $url . '">' . $name . '</a>';
            $html .= '<button type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]" @click="open = !open" :aria-expanded="open.toString()" :aria-label="open ? \'' . $navBlock->escapeHtmlAttr(__('Collapse')) . ' ' . $name . '\' : \'' . $navBlock->escapeHtmlAttr(__('Expand')) . ' ' . $name . '\'">';
            $html .= '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" :style="open ? \'transform:rotate(180deg)\' : \'\'"><polyline points="6 9 12 15 18 9"/></svg>';
            $html .= '</button>';
            $html .= '</div>';
            $html .= '<div class="mt-1" x-show="open" x-transition>' . $renderer($children, $renderer, $navBlock) . '</div>';
        } else {
            $html .= '<a class="block rounded-[var(--radius-button)] px-2.5 py-2 text-sm text-[var(--color-text)] transition-colors hover:bg-[var(--color-bg)] hover:text-[var(--color-accent)]" href="' . $url . '">' . $name . '</a>';
        }

        $html .= '</li>';
    }
    $html .= '</ul>';

    return $html;
};
?>
<aside class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4" aria-label="<?= $escaper->escapeHtmlAttr(__('Category Tree')) ?>">
    <h2 class="mb-3 text-base font-bold"><?= $escaper->escapeHtml(__('Categories')) ?></h2>
    <?= /* @noEscape */ $renderTree(is_iterable($categories) ? iterator_to_array($categories) : [], $renderTree, $block) ?>
</aside>
