<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="contact-index-index"/>

        <!-- Remove every default contact block and page title -->
        <referenceBlock name="contactForm" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Contact\Block\ContactForm" name="thunderbolt.contact.form" template="Magento_Contact::form.phtml" before="-"/>
        </referenceContainer>
    </body>
</page>
