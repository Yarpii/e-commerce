<?xml version="1.0"?>
<layout xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_layout.xsd">
    <update handle="2columns-left"/>
    <referenceContainer
        name="columns"
        htmlClass="columns grid gap-6 xl:grid-cols-[minmax(220px,280px)_minmax(0,1fr)_minmax(220px,280px)] xl:items-start"
    >
        <container
            name="sidebar.additional"
            as="sidebar_additional"
            label="Additional Sidebar"
            htmlTag="aside"
            htmlClass="column sidebar sidebar-additional xl:sticky xl:top-24"
            after="main"
        />
    </referenceContainer>
</layout>
