<?xml version="1.0"?>
<layout xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_layout.xsd">
    <update handle="1column"/>
    <referenceContainer
        name="columns"
        htmlClass="columns grid gap-6 lg:grid-cols-[minmax(240px,300px)_minmax(0,1fr)] lg:items-start"
    >
        <container
            name="sidebar.main"
            as="sidebar_main"
            label="Sidebar"
            htmlTag="aside"
            htmlClass="column sidebar sidebar-main lg:sticky lg:top-24"
            before="main"
        />
    </referenceContainer>
</layout>
