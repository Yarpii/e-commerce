<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <script src="js/catalogsearch-enhancements.js" defer="defer"/>
    </head>
    <body>
        <!-- Hide Magento default page title; custom intro handles heading -->
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="main">
            <block class="Magento\CatalogSearch\Block\Result" name="thunderbolt.catalogsearch.intro" template="Magento_CatalogSearch::result/intro.phtml" before="-"/>
        </referenceContainer>
    </body>
</page>
