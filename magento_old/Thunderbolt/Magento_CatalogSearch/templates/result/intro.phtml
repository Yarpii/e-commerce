<?php
/** @var \Magento\CatalogSearch\Block\Result $block */
$queryText = trim((string) $block->getRequest()->getParam('q'));
$vehicleText = trim((string) $block->getRequest()->getParam('vehicle'));

// Get the result count from the main search.result block which owns the
// search_result_list child.  Our intro block is a separate instance of the
// same class but has no child blocks, so calling $block->getResultCount()
// would crash with "Call to a member function on bool".
$resultCount = 0;
$searchResultBlock = $block->getLayout()->getBlock('search.result');
if ($searchResultBlock) {
    try {
        $resultCount = (int) $searchResultBlock->getResultCount();
    } catch (\Exception $e) {
        $resultCount = 0;
    }
}
$hasResults = $resultCount > 0;
$suggestUrl = $block->getUrl('search/ajax/suggest');
$searchAction = $block->getUrl('catalogsearch/result');

$quickBrandLinks = ['Vespa', 'Piaggio', 'Yamaha', 'SYM', 'Kymco', 'Honda'];
$quickProblemLinks = ['brake pads', 'variator', 'belt kit', 'oil filter', 'headlight'];
$vehicleAwareLinks = $vehicleText !== ''
    ? [
        $vehicleText . ' exhaust',
        $vehicleText . ' brake pads',
        $vehicleText . ' maintenance kit',
        $vehicleText . ' variator'
    ]
    : ['Vespa GTS 300', 'Piaggio MP3 500', 'Yamaha XMAX 300', 'SYM Jet 125'];
?>
