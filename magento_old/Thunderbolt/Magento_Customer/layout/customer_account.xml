<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="sidebar.main">
            <block class="Magento\Customer\Block\Account\Navigation" name="thunderbolt.account.nav" template="Magento_Customer::account/navigation.phtml" before="-">
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-dashboard">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Dashboard</argument>
                        <argument name="path" xsi:type="string">customer/account</argument>
                        <argument name="sortOrder" xsi:type="number">10</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-orders">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Bestellingen</argument>
                        <argument name="path" xsi:type="string">sales/order/history</argument>
                        <argument name="sortOrder" xsi:type="number">20</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-wishlist">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Verlanglijst</argument>
                        <argument name="path" xsi:type="string">wishlist</argument>
                        <argument name="sortOrder" xsi:type="number">30</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-address">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Adresboek</argument>
                        <argument name="path" xsi:type="string">customer/address</argument>
                        <argument name="sortOrder" xsi:type="number">40</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-edit">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Accountgegevens</argument>
                        <argument name="path" xsi:type="string">customer/account/edit</argument>
                        <argument name="sortOrder" xsi:type="number">50</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-reviews">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Mijn reviews</argument>
                        <argument name="path" xsi:type="string">review/customer</argument>
                        <argument name="sortOrder" xsi:type="number">60</argument>
                    </arguments>
                </block>
                <block class="Magento\Customer\Block\Account\SortLink" name="thunderbolt-account-link-newsletter">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Nieuwsbrief</argument>
                        <argument name="path" xsi:type="string">newsletter/manage</argument>
                        <argument name="sortOrder" xsi:type="number">70</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
