<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_form_register" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Form\Register" name="thunderbolt.customer.register" template="Magento_Customer::form/register.phtml">
                <block class="ScooterDynamics\CloudflareCaptcha\Block\Turnstile" name="thunderbolt.customer.register.turnstile" as="turnstile" template="ScooterDynamics_CloudflareCaptcha::turnstile.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
