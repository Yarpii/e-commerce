<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Remove every default block on the login page -->
        <referenceBlock name="customer_form_login" remove="true"/>
        <referenceBlock name="customer.new" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>

        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Form\Login" name="thunderbolt.customer.login" template="Magento_Customer::form/login.phtml">
                <block class="ScooterDynamics\CloudflareCaptcha\Block\Turnstile" name="thunderbolt.customer.login.turnstile" as="turnstile" template="ScooterDynamics_CloudflareCaptcha::turnstile.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
