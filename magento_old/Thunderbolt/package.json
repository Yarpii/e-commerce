{
  "name": "scooterdynamics-thunderbolt-theme",
  "private": true,
  "version": "1.0.0",
  "description": "Tailwind build tooling for the Thunderbolt Magento theme",
  "scripts": {
    "build:tailwind": "postcss ./web/css/source/tailwind.src.css -o ./web/css/source/_tailwind.css --env production",
    "watch:tailwind": "postcss ./web/css/source/tailwind.src.css -o ./web/css/source/_tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.17"
  }
}
